---
import '../styles/global.css'
import type { Lang } from '../i18n/utils'

interface Props {
  title?: string
  description?: string
  lang?: Lang
}

const {
  title = 'Levitere — Cinematic Visual Experiences',
  description = 'Levitere creates cinematic visual content for properties, architecture and selected spaces, combining FPV drone filmmaking, video, photography and digital 3D.',
  lang = 'en',
} = Astro.props

const base = 'https://levitere.vercel.app'

const hreflangs = [
  { hreflang: 'en',    href: `${base}/` },
  { hreflang: 'no',    href: `${base}/no/` },
  { hreflang: 'es',    href: `${base}/es/` },
  { hreflang: 'x-default', href: `${base}/` },
]
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/logo.ico" />

    <!-- Hreflang (SEO multiidioma) -->
    {hreflangs.map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <title>{title}</title>
  </head>
  <body class="bg-[#f5f4f0] text-[#0a0a0a] overflow-x-hidden">
    <slot />
  </body>
</html>