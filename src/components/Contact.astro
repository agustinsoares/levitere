---
// Contact section
---

<section id="contact" class="section-padding px-8 md:px-16 border-t border-muted">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-start">

    <div>
      <p class="text-xs tracking-[0.3em] uppercase text-accent mb-6">Contact</p>
      <h2 class="font-display text-4xl md:text-6xl text-black leading-[1.1] mb-8">
        Let's work<br />
        <em class="italic">together</em>
      </h2>
      <p class="text-muted text-base leading-relaxed max-w-sm mb-10">
        Tell us about your project. We'll get back to you within 24 hours.
      </p>
      <a
        href="mailto:hello@levitere.com"
        class="text-sm tracking-widest uppercase text-muted hover:text-accent transition-colors duration-300"
      >
        hello@levitere.com
      </a>
    </div>

    <form id="contact-form" class="space-y-8 border border-muted rounded-2xl p-8 md:p-10" novalidate>

      <div>
        <label for="name" class="block text-xs tracking-widest uppercase text-muted mb-3">
          Name
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          class="w-full bg-transparent border-b border-muted py-3 text-black placeholder:text-muted focus:outline-none focus:border-accent transition-colors duration-300"
          placeholder="Your name"
        />
      </div>

      <div>
        <label for="email" class="block text-xs tracking-widest uppercase text-muted mb-3">
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="w-full bg-transparent border-b border-muted py-3 text-black placeholder:text-muted focus:outline-none focus:border-accent transition-colors duration-300"
          placeholder="your@email.com"
        />
      </div>

      <div>
        <label for="message" class="block text-xs tracking-widest uppercase text-muted mb-3">
          Message
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="w-full bg-transparent border-b border-muted py-3 text-black placeholder:text-muted focus:outline-none focus:border-accent transition-colors duration-300 resize-none"
          placeholder="Tell us about your project..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="group inline-flex items-center gap-4 text-sm tracking-widest uppercase text-black hover:text-accent transition-colors duration-300 pt-1"
      >
        Send message
        <span class="block w-8 h-px bg-current transition-all duration-300 group-hover:w-14"></span>
      </button>

      <p id="form-status" class="text-sm text-accent hidden"></p>

    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const status = document.getElementById('form-status')

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (status) {
      status.textContent = "Thanks! We'll be in touch soon."
      status.classList.remove('hidden')
    }
    form.reset()
  })
</script>