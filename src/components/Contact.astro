---
// Contact section — simple CTA + email link
// For form functionality: integrate Resend or Formspree later
---

<section id="contact" class="section-padding px-8 md:px-16 border-t border-[#f5f4f0]/10">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-start">

    <!-- Left: CTA -->
    <div>
      <p class="text-xs tracking-[0.3em] uppercase text-[#c8b49a] mb-6">Contact</p>
      <h2 class="font-display font-light text-4xl md:text-6xl text-[#f5f4f0] leading-[1.1] mb-8">
        Let's work<br />
        <em class="italic">together</em>
      </h2>
      <p class="text-[#f5f4f0]/50 text-base leading-relaxed max-w-sm">
        <!-- Replace with real copy -->
        Tell us about your project. We'll get back to you within 24 hours.
      </p>
    </div>

    <!-- Right: Contact form (basic — wire up to Resend later) -->
    <form
      id="contact-form"
      class="space-y-6"
      novalidate
    >
      <div>
        <label for="name" class="block text-xs tracking-widest uppercase text-[#f5f4f0]/40 mb-2">
          Name
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full bg-transparent border-b border-[#f5f4f0]/20 py-3 text-[#f5f4f0] placeholder:text-[#f5f4f0]/20 focus:outline-none focus:border-[#c8b49a] transition-colors duration-300"
          placeholder="Your name"
        />
      </div>

      <div>
        <label for="email" class="block text-xs tracking-widest uppercase text-[#f5f4f0]/40 mb-2">
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full bg-transparent border-b border-[#f5f4f0]/20 py-3 text-[#f5f4f0] placeholder:text-[#f5f4f0]/20 focus:outline-none focus:border-[#c8b49a] transition-colors duration-300"
          placeholder="your@email.com"
        />
      </div>

      <div>
        <label for="message" class="block text-xs tracking-widest uppercase text-[#f5f4f0]/40 mb-2">
          Message
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="w-full bg-transparent border-b border-[#f5f4f0]/20 py-3 text-[#f5f4f0] placeholder:text-[#f5f4f0]/20 focus:outline-none focus:border-[#c8b49a] transition-colors duration-300 resize-none"
          placeholder="Tell us about your project..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="group inline-flex items-center gap-4 text-sm tracking-widest uppercase text-[#f5f4f0] hover:text-[#c8b49a] transition-colors duration-300 pt-2"
      >
        Send message
        <span class="block w-8 h-px bg-current transition-all duration-300 group-hover:w-14"></span>
      </button>

      <!-- Status message -->
      <p id="form-status" class="text-sm text-[#c8b49a] hidden"></p>
    </form>

  </div>
</section>

<script>
  // Placeholder form handler — replace with real API call to Resend/Formspree
  const form = document.getElementById('contact-form') as HTMLFormElement
  const status = document.getElementById('form-status')

  form?.addEventListener('submit', (e) => {
    e.preventDefault()
    // TODO: POST to /api/contact or Formspree endpoint
    if (status) {
      status.textContent = "Thanks! We'll be in touch soon."
      status.classList.remove('hidden')
    }
    form.reset()
  })
</script>
