---
import { useTranslations } from '../i18n/utils'
import type { Lang } from '../i18n/utils'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section id="about" class="section-padding px-8 md:px-16 border-t border-muted">
  <div class="max-w-7xl mx-auto">

    <p class="text-xs tracking-[0.3em] uppercase text-accent mb-16 md:mb-20">{t.about.label}</p>

    <!-- Headline + body -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 mb-16 md:mb-20 items-start">

      <h2 class="font-display text-4xl md:text-5xl text-black leading-[1.15]">
        {t.about.title}<br />
        <em class="italic">{t.about.titleItalic}</em>
      </h2>

      <div class="space-y-5 text-muted text-base leading-relaxed">
        <p>{t.about.p1}</p>
        <p>{t.about.p2}</p>
        <p>{t.about.p3}</p>
        <p>{t.about.p4}</p>

        <div class="pt-6 flex gap-10 border-t border-muted">
          <div>
            <p class="font-display text-xl text-black">Oscar</p>
            <p class="text-xs tracking-widest uppercase text-muted mt-1">{t.about.oscarRole}</p>
          </div>
          <div>
            <p class="font-display text-xl text-black">Emilio</p>
            <p class="text-xs tracking-widest uppercase text-muted mt-1">{t.about.emilioRole}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Presentation video — full width horizontal -->
    <div class="relative w-full aspect-video overflow-hidden bg-white/90 rounded-2xl">
      <video
        class="w-full h-full object-cover"
        autoplay
        muted
        loop
        playsinline
      >
        <source src="/videos/showreel.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-t from-black/15 via-transparent to-transparent pointer-events-none"></div>
    </div>

  </div>
</section>