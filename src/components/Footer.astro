---
import { useTranslations } from '../i18n/utils'
import type { Lang } from '../i18n/utils'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)

const year = new Date().getFullYear()

const socials = [
  { label: 'Instagram', href: '#' },
  { label: 'Vimeo',     href: '#' },
  { label: 'LinkedIn',  href: '#' },
]
---

<footer class="px-8 md:px-16 py-14 border-t border-muted">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

    <a href="/" aria-label="Levitere — Home">
      <img
        src="/images/logo_name.png"
        alt="Levitere"
        class="h-12 w-auto object-contain opacity-30 hover:opacity-80 transition-opacity duration-300"
        style="filter: invert(1);"
      />
    </a>

    <ul class="flex items-center gap-8">
      {socials.map((s) => (
        <li>
          <a
            href={s.href}
            class="text-xs tracking-widest uppercase text-muted hover:text-black transition-colors duration-300"
            target="_blank"
            rel="noopener noreferrer"
          >
            {s.label}
          </a>
        </li>
      ))}
    </ul>

    <p class="text-xs text-muted tracking-wider">
      © {year} Levitere
    </p>

  </div>
</footer>