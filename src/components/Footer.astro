---
const year = new Date().getFullYear()

const socials = [
  { label: 'Instagram', href: '#' },
  { label: 'Vimeo', href: '#' },
  { label: 'LinkedIn', href: '#' },
]
---

<footer class="px-8 md:px-16 py-14 border-t border-[#f5f4f0]/10">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

    <!-- Logo with name -->
    <a href="/" aria-label="Levitere — Home">
      <img
        src="/images/logo_name.png"
        alt="Levitere"
        class="h-6 w-auto object-contain opacity-40 hover:opacity-100 transition-opacity duration-300"
      />
    </a>

    <!-- Social links -->
    <ul class="flex items-center gap-8">
      {socials.map((s) => (
        <li>
          <a
            href={s.href}
            class="text-xs tracking-widest uppercase text-[#f5f4f0]/30 hover:text-[#f5f4f0] transition-colors duration-300"
            target="_blank"
            rel="noopener noreferrer"
          >
            {s.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Copyright -->
    <p class="text-xs text-[#f5f4f0]/20 tracking-wider">
      © {year} Levitere
    </p>

  </div>
</footer>