---
const year = new Date().getFullYear()

const socials = [
  { label: 'Instagram', href: '#' },
  { label: 'Vimeo', href: '#' },
  { label: 'LinkedIn', href: '#' },
]
---

<footer class="px-8 md:px-16 py-14 border-t border-[#0a0a0a]/10">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

    <a href="/" aria-label="Levitere — Home">
      <img
        src="/images/logo_nombre.png"
        alt="Levitere"
        class="h-6 w-auto object-contain opacity-30 hover:opacity-80 transition-opacity duration-300"
        style="filter: invert(1);"
      />
    </a>

    <ul class="flex items-center gap-8">
      {socials.map((s) => (
        <li>
          <a
            href={s.href}
            class="text-xs tracking-widest uppercase text-[#0a0a0a]/30 hover:text-[#0a0a0a] transition-colors duration-300"
            target="_blank"
            rel="noopener noreferrer"
          >
            {s.label}
          </a>
        </li>
      ))}
    </ul>

    <p class="text-xs text-[#0a0a0a]/20 tracking-wider">
      © {year} Levitere
    </p>

  </div>
</footer>
