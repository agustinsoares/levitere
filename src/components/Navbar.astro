---
const navLinks = [
  { label: 'Work', href: '#work' },
  { label: 'About', href: '#about' },
  { label: 'Services', href: '#services' },
  { label: 'Contact', href: '#contact' },
]
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <nav class="flex items-center justify-between px-8 py-6 md:px-16">
    <!-- Logo -->
    <a href="/" class="font-display text-xl tracking-widest uppercase text-[#f5f4f0]">
      Levitere
    </a>

    <!-- Links -->
    <ul class="hidden md:flex items-center gap-10">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm tracking-widest uppercase text-[#f5f4f0]/60 hover:text-[#f5f4f0] transition-colors duration-300"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile menu button (placeholder) -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
    >
      <span class="block w-6 h-px bg-[#f5f4f0]"></span>
      <span class="block w-6 h-px bg-[#f5f4f0]"></span>
    </button>
  </nav>
</header>

<script>
  // Navbar background on scroll
  const navbar = document.getElementById('navbar')
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      navbar?.classList.add('bg-[#0a0a0a]/90', 'backdrop-blur-sm')
    } else {
      navbar?.classList.remove('bg-[#0a0a0a]/90', 'backdrop-blur-sm')
    }
  })
</script>
