---
const navLinks = [
  { label: 'Work', href: '#work' },
  { label: 'About', href: '#about' },
  { label: 'Services', href: '#services' },
  { label: 'Contact', href: '#contact' },
]
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <nav class="flex items-center justify-between px-8 py-5 md:px-16">

    <!-- Logo -->
    <a href="/" aria-label="Levitere — Home">
      <img
        src="/images/logo_name.png"
        alt="Levitere"
        class="h-7 md:h-8 w-auto object-contain"
      />
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-10">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            id={`nav-${link.label.toLowerCase()}`}
            class="nav-link text-sm tracking-widest uppercase transition-colors duration-300 text-[#f5f4f0]/70 hover:text-[#f5f4f0]"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-[5px] p-2"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span id="bar-1" class="block w-6 h-px bg-[#f5f4f0] transition-all duration-300"></span>
      <span id="bar-2" class="block w-6 h-px bg-[#f5f4f0] transition-all duration-300"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden flex-col px-8 pb-8 gap-6"
  >
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-link text-sm tracking-widest uppercase transition-colors duration-300"
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')
  const navLinks = document.querySelectorAll('.nav-link')
  const mobileLinks = document.querySelectorAll('.mobile-link')
  const bar1 = document.getElementById('bar-1')
  const bar2 = document.getElementById('bar-2')
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')

  // Hero height threshold
  function getHeroHeight(): number {
    return window.innerHeight
  }

  function setLight() {
    // White background, dark text
    navbar?.classList.add('bg-[#f5f4f0]', 'shadow-sm')
    navbar?.classList.remove('bg-transparent')
    navLinks.forEach(l => {
      l.classList.remove('text-[#f5f4f0]/70', 'hover:text-[#f5f4f0]')
      l.classList.add('text-[#0a0a0a]/60', 'hover:text-[#0a0a0a]')
    })
    mobileLinks.forEach(l => {
      l.classList.remove('text-[#f5f4f0]/70')
      l.classList.add('text-[#0a0a0a]/60')
    })
    if (bar1) bar1.classList.replace('bg-[#f5f4f0]', 'bg-[#0a0a0a]')
    if (bar2) bar2.classList.replace('bg-[#f5f4f0]', 'bg-[#0a0a0a]')
    if (menu) menu.classList.add('bg-[#f5f4f0]')
  }

  function setDark() {
    // Transparent background, white text (over hero video)
    navbar?.classList.remove('bg-[#f5f4f0]', 'shadow-sm')
    navbar?.classList.add('bg-transparent')
    navLinks.forEach(l => {
      l.classList.add('text-[#f5f4f0]/70', 'hover:text-[#f5f4f0]')
      l.classList.remove('text-[#0a0a0a]/60', 'hover:text-[#0a0a0a]')
    })
    mobileLinks.forEach(l => {
      l.classList.add('text-[#f5f4f0]/70')
      l.classList.remove('text-[#0a0a0a]/60')
    })
    if (bar1) bar1.classList.replace('bg-[#0a0a0a]', 'bg-[#f5f4f0]')
    if (bar2) bar2.classList.replace('bg-[#0a0a0a]', 'bg-[#f5f4f0]')
    if (menu) menu.classList.remove('bg-[#f5f4f0]')
  }

  // Initial state: over hero = dark
  setDark()

  window.addEventListener('scroll', () => {
    if (window.scrollY >= getHeroHeight() - 80) {
      setLight()
    } else {
      setDark()
    }
  })

  // Mobile toggle
  let open = false
  toggle?.addEventListener('click', () => {
    open = !open
    if (open) {
      menu?.classList.remove('hidden')
      menu?.classList.add('flex')
      bar1?.classList.add('rotate-45', 'translate-y-[7px]')
      bar2?.classList.add('-rotate-45')
      toggle.setAttribute('aria-expanded', 'true')
    } else {
      menu?.classList.add('hidden')
      menu?.classList.remove('flex')
      bar1?.classList.remove('rotate-45', 'translate-y-[7px]')
      bar2?.classList.remove('-rotate-45')
      toggle.setAttribute('aria-expanded', 'false')
    }
  })

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      open = false
      menu?.classList.add('hidden')
      menu?.classList.remove('flex')
      bar1?.classList.remove('rotate-45', 'translate-y-[7px]')
      bar2?.classList.remove('-rotate-45')
      toggle?.setAttribute('aria-expanded', 'false')
    })
  })
</script>
