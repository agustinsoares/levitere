---
import { useTranslations } from '../i18n/utils'
import type { Lang } from '../i18n/utils'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)

const projects: {
  id: string
  title: string
  category: string
  location: string
  src: string
  wide?: boolean
}[] = [
  // Descomenta y añade proyectos aquí cuando estén listos:
  // {
  //   id: '01',
  //   title: 'Nombre del proyecto',
  //   category: 'FPV Drone',
  //   location: 'Bergen, NO',
  //   src: '/images/projects/project-1.jpg',
  //   wide: true,
  // },
]
---

<section id="work" class="section-padding px-8 md:px-16 border-t border-muted">
  <div class="max-w-7xl mx-auto">

    <div class="mb-16 md:mb-20">
      <p class="text-xs tracking-[0.3em] uppercase text-accent mb-4">{t.work.label}</p>
      <h2 class="font-display text-4xl md:text-6xl text-black">
        {t.work.title}
      </h2>
    </div>

    {projects.length === 0 ? (
      <div class="flex items-center justify-center py-32 border border-muted rounded-2xl">
        <div class="text-center">
          <p class="font-display text-2xl text-black mb-3">{t.work.empty}</p>
          <p class="text-sm text-muted tracking-wide">{t.work.emptySub}</p>
        </div>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {projects.map((project) => (
          <div class:list={['group relative overflow-hidden rounded-2xl bg-black aspect-video', project.wide && 'md:col-span-2']}>
            <img
              src={project.src}
              alt={project.title}
              class="w-full h-full object-cover opacity-80 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8">
              <p class="text-xs tracking-widest uppercase text-accent mb-2">{project.category} — {project.location}</p>
              <p class="font-display text-2xl text-white">{project.id} {project.title}</p>
            </div>
          </div>
        ))}
      </div>
    )}

  </div>
</section>