---
const projects: Array<{
  id: string
  title: string
  category: string
  location: string
  src?: string
  wide?: boolean
}> = [
  // Añadir proyectos aquí cuando estén listos:
  // {
  //   id: '01',
  //   title: 'Project Name',
  //   category: 'FPV Drone',
  //   location: 'Valencia, ES',
  //   src: '/images/projects/project-1.jpg',
  //   wide: true,
  // },
]

const hasProjects = projects.length > 0
---

<section id="work" class="section-padding px-8 md:px-16 border-t border-muted">
  <div class="max-w-7xl mx-auto">

    <div class="flex items-end justify-between mb-16 md:mb-24">
      <div>
        <p class="text-xs tracking-[0.3em] uppercase text-accent mb-4">Portfolio</p>
        <h2 class="font-display text-4xl md:text-6xl text-black">
          Selected work
        </h2>
      </div>
      {hasProjects && (
        <span class="hidden md:block text-sm text-muted tracking-widest">
          {projects.length} projects
        </span>
      )}
    </div>

    {hasProjects ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {projects.map((project, i) => (
          <article class={`group cursor-pointer ${project.wide ? 'md:col-span-2' : ''}`}>
            <div class={`relative overflow-hidden bg-white/90 ${project.wide ? 'aspect-[16/7]' : 'aspect-[4/3]'}`}>
              {project.src && (
                <img
                  src={project.src}
                  alt={project.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              )}
              <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            </div>
            <div class="flex items-start justify-between mt-4">
              <div>
                <h3 class="font-display text-xl md:text-2xl text-black group-hover:text-accent transition-colors duration-300">
                  {project.title}
                </h3>
                <p class="text-sm text-muted mt-1">{project.category} — {project.location}</p>
              </div>
              <span class="text-xs text-muted tracking-widest mt-1">{project.id}</span>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="border border-muted rounded-2xl p-16 md:p-24 text-center">
        <p class="font-display text-2xl text-muted italic">Projects coming soon</p>
        <p class="text-xs tracking-widest uppercase text-muted mt-3">
          Our portfolio is being prepared
        </p>
      </div>
    )}

  </div>
</section>